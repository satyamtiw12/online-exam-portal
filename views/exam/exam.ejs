<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Exam Screen</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body{font-family:Arial,sans-serif;background:#f2f2f2;margin:0;}
    .exam-header{background:#e9e9e9;padding:15px 25px;display:flex;
      justify-content:space-between;align-items:center;border-bottom:1px solid #ccc;font-weight:bold;}
    .exam-container{width:750px;margin:30px auto;background:#fff;padding:25px 35px;
      border-radius:6px;box-shadow:0 4px 10px rgba(0,0,0,0.08);}
    .question-count{font-size:20px;font-weight:bold;margin-bottom:15px;}
    .question-text{font-size:18px;margin-bottom:20px;}
    .option{margin:12px 0;font-size:16px;}
    .button-row{margin-top:25px;display:flex;justify-content:space-between;}
    .nav-btn{padding:8px 20px;border:1px solid #b5b5b5;background:#f5f5f5;border-radius:4px;cursor:pointer;}
    .nav-btn:hover{background:#e1e1e1;}
    .next-btn{background:#3a7bd5;color:#fff;border:none;}
    .next-btn:hover{background:#2c5fa3;}
    .submit-container{text-align:center;margin-top:20px;}
    .submit-btn{background:#3a7bd5;color:#fff;padding:10px 30px;border:none;
      border-radius:5px;font-size:16px;cursor:pointer;}
    .submit-btn:hover{background:#2c5fa3;}
    .modal{position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.5);
      display:flex;align-items:center;justify-content:center;visibility:hidden;opacity:0;transition:0.3s;z-index:9999;}
    .modal.active{visibility:visible;opacity:1;}
    .modal-box{background:#fff;padding:30px 40px;border-radius:8px;text-align:center;
      width:350px;box-shadow:0 10px 25px rgba(0,0,0,0.2);}
  </style>
  <script>
    let timeLeft = <%= duration %>;
    let isSubmitting = false;
    let questions = <%- questions %>;
    let currentIndex = 0;
    let answers = {};

    function startTimer(){
      let timer = setInterval(function(){
        let m = Math.floor(timeLeft/60), s = timeLeft % 60;
        document.getElementById('timer').innerHTML = m + ':' + (s<10?'0'+s:s);
        timeLeft--;
        if(timeLeft < 0){ clearInterval(timer); submitExam('Time is up! Submitting...'); }
      }, 1000);
    }

    function showModal(msg){
      document.getElementById('modalMsg').innerText = msg;
      document.getElementById('submitModal').classList.add('active');
    }

    function submitExam(msg){
      if(isSubmitting) return;
      isSubmitting = true;
      showModal(msg);
      document.getElementById('answersInput').value = JSON.stringify(answers);
      setTimeout(() => document.getElementById('examForm').submit(), 1000);
    }

    function manualSubmit(){ submitExam('Submitting your exam...'); }

    document.addEventListener('visibilitychange', function(){
      if(document.hidden && !isSubmitting) submitExam('Tab switch detected. Auto submitting...');
    });
    document.addEventListener('contextmenu', e => e.preventDefault());
    history.pushState(null, null, location.href);
    window.onpopstate = () => history.go(1);

    function renderQuestion(idx){
      const q = questions[idx];
      const c = document.getElementById('examContainer');
      c.innerHTML = `
        <div class="question-count">Question ${idx+1}/${questions.length}</div>
        <div class="question-text">${q.question}</div>
        <div class="option"><label><input type="radio" name="q${q.id}" value="A" ${answers[q.id]==='A'?'checked':''}> ${q.option_a}</label></div>
        <div class="option"><label><input type="radio" name="q${q.id}" value="B" ${answers[q.id]==='B'?'checked':''}> ${q.option_b}</label></div>
        <div class="option"><label><input type="radio" name="q${q.id}" value="C" ${answers[q.id]==='C'?'checked':''}> ${q.option_c}</label></div>
        <div class="option"><label><input type="radio" name="q${q.id}" value="D" ${answers[q.id]==='D'?'checked':''}> ${q.option_d}</label></div>
        <div class="button-row">
          <button class="nav-btn" id="prevBtn" ${idx===0?'style="display:none"':''}>◀ Previous</button>
          <button class="nav-btn next-btn" id="nextBtn" ${idx===questions.length-1?'style="display:none"':''}>Next ▶</button>
        </div>
        ${idx===questions.length-1 ? '<div class="submit-container"><button class="submit-btn" onclick="manualSubmit()">Submit Exam</button></div>' : ''}
      `;
      c.querySelectorAll('input[type="radio"]').forEach(opt => {
        opt.addEventListener('change', () => answers[q.id] = opt.value);
      });
      const p = document.getElementById('prevBtn');
      const n = document.getElementById('nextBtn');
      if(p) p.onclick = () => { currentIndex--; renderQuestion(currentIndex); };
      if(n) n.onclick = () => { currentIndex++; renderQuestion(currentIndex); };
    }

    window.onload = function(){ startTimer(); renderQuestion(0); };
  </script>
</head>
<body>
<div class="exam-header">
  <div>Exam Screen</div>
  <div>Time Left: <span id="timer"></span></div>
</div>

<form id="examForm" action="/submit" method="POST">
  <input type="hidden" name="exam_id" value="<%= exam.id %>">
  <input type="hidden" id="answersInput" name="answers">
  <div class="exam-container" id="examContainer"></div>
</form>

<div class="modal" id="submitModal">
  <div class="modal-box">
    <h3 id="modalMsg">Submitting...</h3>
  </div>
</div>
</body>
</html>
