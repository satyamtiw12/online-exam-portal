<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Create Exam</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif;}
    body{background:#f4f6f9;padding:40px;}
    .container{max-width:600px;margin:auto;}
    .back{display:inline-block;margin-bottom:20px;padding:8px 16px;
      background:#667eea;color:white;text-decoration:none;border-radius:6px;}
    .card{background:white;padding:30px;border-radius:12px;
      box-shadow:0 8px 20px rgba(0,0,0,0.08);}
    h2{margin-bottom:25px;color:#333;}
    label{display:block;font-size:13px;font-weight:600;color:#555;
      margin-bottom:5px;margin-top:15px;}
    input,textarea,select{width:100%;padding:12px;border:1px solid #ddd;
      border-radius:8px;font-size:15px;}
    textarea{resize:none;height:80px;}
    .row{display:grid;grid-template-columns:1fr 1fr;gap:15px;}
    button{width:100%;margin-top:20px;padding:14px;background:#667eea;
      color:white;border:none;border-radius:8px;font-size:16px;
      font-weight:600;cursor:pointer;}
    button:hover{background:#5563c1;}
    .hint{font-size:12px;color:#888;margin-top:4px;}
  </style>
</head>
<body>
<div class="container">
  <a href="/admin/dashboard" class="back">← Back to Dashboard</a>
  <div class="card">
    <h2>Create New Exam</h2>
    <%- include('../partials/flash') %>
    <form method="POST" action="/admin/create-exam">

      <label>Exam Title</label>
      <input type="text" name="exam_title" placeholder="e.g. Java Programming" required>

      <div class="row">
        <div>
          <label>Exam Date</label>
          <input type="date" name="exam_date" required>
        </div>
        <div>
          <label>Duration (Minutes)</label>
          <input type="number" name="duration" placeholder="e.g. 60" required>
        </div>
      </div>

      <div class="row">
        <div>
          <label>Total Marks</label>
          <input type="number" name="total_marks" placeholder="e.g. 100" value="100" required>
        </div>
        <div>
          <label>Pass Marks</label>
          <input type="number" name="pass_marks" placeholder="e.g. 40" value="40" required>
        </div>
      </div>

      <div class="row">
        <div>
          <label>Negative Marking</label>
          <select name="negative_marking">
            <option value="0">No Negative Marking</option>
            <option value="0.25">0.25 per wrong</option>
            <option value="0.50">0.50 per wrong</option>
            <option value="1">1 per wrong</option>
          </select>
          <p class="hint">Marks deducted per wrong answer</p>
        </div>
        <div>
          <label>Expiry Date & Time</label>
          <input type="datetime-local" name="expiry_date" required>
        </div>
      </div>

      <label>Exam Instructions</label>
      <textarea name="instructions" placeholder="e.g. All questions are compulsory..."></textarea>

      <button type="submit">Create Exam ✅</button>
    </form>
  </div>
</div>
</body>
</html>