<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Admin Dashboard</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif;}
    body{display:flex;background:#f4f6f9;min-height:100vh;}
    .sidebar{width:250px;height:100vh;background:linear-gradient(180deg,#141e30,#243b55);
      padding:25px;color:white;position:fixed;}
    .sidebar h2{margin-bottom:30px;font-weight:600;}
    .sidebar a{display:block;color:white;text-decoration:none;margin:15px 0;
      padding:10px;border-radius:6px;transition:0.3s;}
    .sidebar a:hover{background:rgba(255,255,255,0.2);}
    .main{margin-left:250px;padding:40px;flex:1;}
    .header{background:white;padding:25px;border-radius:15px;
      box-shadow:0 8px 20px rgba(0,0,0,0.08);margin-bottom:30px;}
    .header h1{font-size:28px;font-weight:700;}
    .stat-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-bottom:30px;}
    .stat{background:white;padding:25px;border-radius:15px;
      box-shadow:0 8px 20px rgba(0,0,0,0.08);transition:0.3s;}
    .stat:hover{transform:translateY(-5px);}
    .stat h3{color:#888;font-size:14px;margin-bottom:10px;text-transform:uppercase;}
    .stat .num{font-size:36px;font-weight:700;color:#333;}
    .stat a{display:inline-block;margin-top:15px;padding:8px 16px;border-radius:6px;
      text-decoration:none;font-weight:600;font-size:13px;color:white;}
    .green{background:#28a745;}.blue{background:#007bff;}.yellow{background:#ffc107;color:#333!important;}
    table{width:100%;border-collapse:collapse;background:white;border-radius:10px;
      overflow:hidden;box-shadow:0 5px 20px rgba(0,0,0,0.05);}
    th,td{padding:12px;text-align:center;border-bottom:1px solid #ddd;}
    th{background:#667eea;color:white;}
    tr:nth-child(even){background:#f9f9f9;}
    .del{background:#dc3545;padding:5px 12px;border-radius:5px;color:white;
      text-decoration:none;font-weight:600;font-size:13px;}
    h2{margin-bottom:15px;color:#333;}
    h2.st{
      color: #f4f6f9;
    }
  </style>
</head>
<body>
<div class="sidebar">
  <h2 class="st">Admin Panel</h2>
  <a href="/admin/dashboard">Dashboard</a>
  <a href="/admin/students">Students</a>
  <a href="/admin/add-question">Add Question</a>
  <a href="/admin/manage-questions">Manage Questions</a>
  <a href="/admin/create-exam">Create Exam</a>
  <a href="/logout">Logout</a>
  
</div>
<div class="main">
  <div class="header">
    <h1>Welcome, <%= session.username %> 👋</h1>
    <p style="color:#666;margin-top:5px;">Admin Panel Overview</p>
  </div>

  <%- include('../partials/flash') %>

  <div class="stat-cards">
    <div class="stat">
      <h3>Total Questions</h3>
      <div class="num"><%= totalQuestions %></div>
      <a href="/admin/manage-questions" class="green">Manage</a>
    </div>
    <div class="stat">
      <h3>Total Exams</h3>
      <div class="num"><%= totalExams %> <span style="font-size:16px;color:#888;">| Active: <%= activeExams %></span></div>
      <a href="/admin/create-exam" class="blue">Create / Manage</a>
    </div>
    <div class="stat">
      <h3>Total Students</h3>
      <div class="num"><%= totalStudents %></div>
    </div>
  </div>

  <h2>Recent Results</h2>
  <table>
    <tr><th>ID</th><th>Student</th><th>Exam</th><th>Score</th><th>Total</th><th>Submitted</th><th>Action</th></tr>
    <% results.forEach(r => { %>
    <tr>
      <td><%= r.id %></td>
      <td><%= r.username %></td>
      <td><%= r.exam_title %></td>
      <td><%= r.score %></td>
      <td><%= r.total_marks %></td>
      <td><%= new Date(r.submitted_at).toLocaleString('en-IN') %></td>
      <td><a class="del" href="/admin/delete-result/<%= r.id %>" onclick="return confirm('Delete?')">Delete</a></td>
    </tr>
    <% }) %>
  </table>
</div>
</body>
</html>
