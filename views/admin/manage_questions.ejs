<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Manage Questions</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif;}
    body{background:#f4f6f9;padding:30px;}
    .header-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;}
    h2{color:#333;}
    .btn{padding:8px 16px;border-radius:6px;text-decoration:none;color:white;
      font-weight:600;font-size:14px;}
    .btn-add{background:#667eea;}.btn-back{background:#dc3545;}
    table{width:100%;border-collapse:collapse;background:white;border-radius:10px;overflow:hidden;
      box-shadow:0 5px 20px rgba(0,0,0,0.06);}
    th,td{padding:11px 13px;border-bottom:1px solid #ddd;text-align:left;font-size:14px;}
    th{background:#667eea;color:white;}
    tr:hover{background:#f5f5f5;}
    .actions{display:flex;flex-direction:column;gap:5px;}
    .btn-edit{background:#667eea;padding:5px 10px;border-radius:5px;color:white;
      text-decoration:none;font-size:12px;text-align:center;}
    .btn-del{background:#dc3545;padding:5px 10px;border-radius:5px;color:white;
      text-decoration:none;font-size:12px;text-align:center;}
  </style>
</head>
<body>
<div class="header-row">
  <h2>Manage Questions</h2>
  <div>
    <a href="/admin/add-question" class="btn btn-add">Add New Question</a>
    <a href="/admin/dashboard" class="btn btn-back" style="margin-left:10px;">Back to Dashboard</a>
  </div>
</div>
<%- include('../partials/flash') %>
<table>
  <tr><th>ID</th><th>Exam ID</th><th>Question</th><th>A</th><th>B</th><th>C</th><th>D</th><th>Answer</th><th>Actions</th></tr>
  <% questions.forEach(q => { %>
  <tr>
    <td><%= q.id %></td>
    <td><%= q.exam_id %></td>
    <td><%= q.question %></td>
    <td><%= q.option_a %></td>
    <td><%= q.option_b %></td>
    <td><%= q.option_c %></td>
    <td><%= q.option_d %></td>
    <td><strong><%= q.correct_option %></strong></td>
    <td>
      <div class="actions">
        <a class="btn-edit" href="/admin/edit-question/<%= q.id %>">Edit</a>
        <a class="btn-del" href="/admin/delete-question/<%= q.id %>" onclick="return confirm('Are you sure?')">Delete</a>
      </div>
    </td>
  </tr>
  <% }) %>
</table>
</body>
</html>
