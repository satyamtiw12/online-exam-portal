<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><title>Profile</title>
  <style>
    *{margin:0;padding:0;box-sizing:border-box;font-family:'Segoe UI',sans-serif;}
    body{background:#f4f6f9;min-height:100vh;}
    .navbar{display:flex;justify-content:space-between;align-items:center;
      padding:15px 40px;background:#1e293b;color:white;}
    .navbar strong{font-size:18px;}
    .nav-links a{padding:8px 16px;border-radius:6px;text-decoration:none;
      font-weight:500;margin-left:10px;}
    .btn-dashboard{background:#38bdf8;color:#000;}
    .btn-logout{background:#ef4444;color:#fff;}
    .container{max-width:800px;margin:40px auto;padding:0 20px;}
    .card{background:white;padding:30px;border-radius:12px;
      box-shadow:0 8px 20px rgba(0,0,0,0.08);margin-bottom:25px;}
    .profile-top{display:flex;gap:30px;align-items:center;}
    .profile-top img{width:120px;height:120px;border-radius:50%;object-fit:cover;
      border:3px solid #667eea;}
    .profile-top p{margin:5px 0;font-size:16px;}
    .section-title{font-size:18px;font-weight:700;margin-bottom:15px;color:#333;}
    label{display:block;font-size:13px;font-weight:600;color:#555;margin-bottom:5px;}
    input{width:100%;padding:12px;border:1px solid #ddd;border-radius:8px;
      font-size:15px;margin-bottom:15px;}
    button{padding:10px 20px;background:#667eea;color:white;border:none;
      border-radius:8px;font-weight:600;cursor:pointer;transition:0.3s;}
    button:hover{background:#5563c1;}
  </style>
</head>
<body>
<div class="navbar">
  <strong>Profile</strong>
  <div class="nav-links">
    <a href="/dashboard" class="btn-dashboard">Dashboard</a>
    <a href="/logout" class="btn-logout">Logout</a>
  </div>
</div>
<div class="container">
  <%- include('../partials/flash') %>

  <div class="card">
    <div class="profile-top">
      <img src="<%= user.profile_photo ? '/uploads/' + user.profile_photo : 'https://via.placeholder.com/120' %>" alt="Profile">
      <div>
        <p><strong>Username:</strong> <%= user.username %></p>
        <p><strong>Email:</strong> <%= user.email %></p>
        <p><strong>Role:</strong> <%= user.role %></p>
      </div>
    </div>
  </div>

  <div class="card">
    <div class="section-title">Edit Email</div>
    <form method="POST" action="/profile/update">
      <label>Email</label>
      <input type="email" name="email" value="<%= user.email %>" required>
      <button type="submit">Update</button>
    </form>
  </div>

  <div class="card">
    <div class="section-title">Change Profile Photo</div>
    <form method="POST" action="/profile/photo" enctype="multipart/form-data">
      <label>Choose Photo</label>
      <input type="file" name="photo" required>
      <button type="submit">Upload</button>
    </form>
  </div>
</div>
</body>
</html>
