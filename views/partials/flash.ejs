<!-- Flash Messages -->
<% if (success && success.length > 0) { %>
  <div class="flash-success"><%= success %></div>
<% } %>
<% if (error && error.length > 0) { %>
  <div class="flash-error"><%= error %></div>
<% } %>

<style>
.flash-success { background:#d4edda; color:#155724; padding:12px 20px; border-radius:8px; margin:10px 0; font-weight:600; }
.flash-error   { background:#f8d7da; color:#721c24; padding:12px 20px; border-radius:8px; margin:10px 0; font-weight:600; }
</style>
